      "Bash(sudo gem install cocoapods)",
      "Bash(pod --version)",
      "Bash(find /usr/local/bin /usr/bin /opt/homebrew/bin ~/.gem /Library/Ruby -name \"pod\" 2>/dev/null | head -5)",
      "Read(//usr/local/bin/**)",
      "Bash(find /Library/Ruby /usr/local -name \"pod\" -type f 2>/dev/null | head -5)",
      "Read(//Library/Ruby/**)",
      "Bash(gem environment *)"
