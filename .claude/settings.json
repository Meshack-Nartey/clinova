{
  "permissions": {
    "allow": [
      "Bash(flutter run *)",
      "Bash(echo \"PID: $!\")",
      "Bash(tmux new-session *)",
      "Bash(tmux send-keys *)",
      "Bash(brew install *)",
      "Bash(xcode-select -p)",
      "Bash(xcrun --find xcodebuild)",
      "Bash(ls /Applications/ | grep -i xcode && ls /Applications/Xcode.app/Contents/Developer/usr/bin/xcodebuild 2>/dev/null || echo \"Xcode.app not found\")",
      "Read(//Applications/**)",
      "Read(//Applications/Xcode.app/Contents/Developer/usr/bin/**)",
      "Bash(sudo xcode-select --switch /Applications/Xcode.app/Contents/Developer)",
